{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",
    "lib": ["ES2020"],
    "outDir": "dist-cli",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": false,
    "allowImportingTsExtensions": false,
    "noEmit": false
  },
  "include": ["cli/**/*.ts", "cli/**/*.d.ts", "src/modules/quality-core.ts"]
}
